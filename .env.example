# .env.example — Environment variables for ARIA
# Copy to .env and fill in values as needed.

# Ollama base URL (defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model override (defaults to llama3)
OLLAMA_MODEL=gemma4:latest

# Telegram bot token (if Telegram integration is enabled)
TELEGRAM_BOT_TOKEN=

# Google Drive credentials path
GOOGLE_DRIVE_CREDENTIALS_PATH=~/.aria/google_credentials.json

# Log level override: TRACE | DEBUG | INFO | WARNING | ERROR
ARIA_LOG_LEVEL=INFO
